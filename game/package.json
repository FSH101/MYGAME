{
  "name": "wasteland-survival",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "dev:client": "cd client && vite",
    "dev:server": "tsx watch src/fastify.ts",
    "build:client": "cd client && vite build",
    "build:server": "cd server && tsc -p tsconfig.json",
    "start": "node server/dist/fastify.js",
    "lint": "eslint \"client/src/**/*.{ts,tsx}\" \"server/src/**/*.ts\" \"shared/**/*.ts\"",
    "format": "prettier --write .",
    "docker:build": "docker build -f server/docker/Dockerfile -t wasteland-survival .",
    "docker:run": "docker run -p 8080:8080 wasteland-survival",
    "test:load": "cd server && ts-node src/sim/bots.ts"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "dependencies": {
    "@babylonjs/core": "^6.40.0",
    "@babylonjs/loaders": "^6.40.0",
    "@babylonjs/materials": "^6.40.0",
    "@colyseus/schema": "^2.0.27",
    "@dimforge/rapier3d-compat": "^0.11.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.1",
    "@lukeed/uuid": "^2.0.1",
    "@prisma/client": "^5.15.0",
    "babylonjs-gui": "^6.40.0",
    "cannon-es": "^0.20.0",
    "colyseus": "^0.15.17",
    "fastify": "^4.28.0",
    "prisma": "^5.15.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
